# Production Environment Variables Template
# Copy this to .env.production and fill in real values

# Database (use managed PostgreSQL with PostGIS)
DATABASE_URL="postgresql://username:password@your-db-host:5432/raastaa?schema=public"

# JWT Secrets (GENERATE NEW SECURE SECRETS - DO NOT USE DEFAULTS)
JWT_SECRET="CHANGE_THIS_TO_RANDOM_64_CHAR_STRING"
JWT_REFRESH_SECRET="CHANGE_THIS_TO_ANOTHER_RANDOM_64_CHAR_STRING"

# Redis (use managed Redis)
REDIS_URL="redis://username:password@your-redis-host:6379"

# Server
PORT=3000
NODE_ENV="production"

# CORS - Add your production domain
CORS_ORIGINS="https://yourdomain.com,https://www.yourdomain.com"

# Rate Limiting (stricter in production)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL="warn"

# Optional: Error tracking (Sentry)
# SENTRY_DSN="your-sentry-dsn"

# Optional: Email service (for password reset, etc)
# SMTP_HOST="smtp.gmail.com"
# SMTP_PORT=587
# SMTP_USER="your-email@gmail.com"
# SMTP_PASSWORD="your-app-password"
