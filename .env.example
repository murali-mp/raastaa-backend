# Environment
NODE_ENV=development
API_PORT=3000
API_HOST=localhost

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/raastaa?schema=public
DATABASE_POOL_MIN=5
DATABASE_POOL_MAX=25

# Redis
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# JWT
JWT_SECRET=your-super-secret-key-change-this-in-production
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=30d

# AWS S3 / CloudFlare R2
S3_BUCKET_NAME=raastaa-media
S3_ACCESS_KEY=your-access-key
S3_SECRET_KEY=your-secret-key
S3_REGION=us-east-1
S3_ENDPOINT=
S3_PUBLIC_URL=https://cdn.raastaa.com

# APNs (Apple Push Notifications)
APNS_KEY_PATH=/path/to/AuthKey_KEYID.p8
APNS_KEY_ID=YOUR_KEY_ID
APNS_TEAM_ID=YOUR_TEAM_ID
APNS_BUNDLE_ID=com.raastaa.app
APNS_PRODUCTION=false

# Monitoring
SENTRY_DSN=
LOG_LEVEL=info

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# CORS
CORS_ORIGIN=raastaa://,http://localhost:3000

# Feature Flags
ENABLE_EMAIL_VERIFICATION=false
ENABLE_GPS_VERIFICATION=true
ENABLE_PROFANITY_FILTER=true
